# Create .htpasswd before first start - REQUIRED for Traefik BasicAuth
#
# Linux/Mac:
#   ./scripts/generate-auth.sh admin
#
# Windows (PowerShell):
#   .\scripts\generate-auth.ps1 -Username admin
#
# Or manually with Docker:
#   docker run --rm httpd:alpine htpasswd -nbB admin YOUR_PASSWORD > traefik/auth/.htpasswd
#
# This protects: pgAdmin, Portainer, Uptime Kuma, Traefik dashboard
