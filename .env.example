# =============================================================================
# Docker Infrastructure - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to version control. Add .env to .gitignore.
# =============================================================================

# -----------------------------------------------------------------------------
# Domain Configuration (Infra Admin GUIs Only)
# -----------------------------------------------------------------------------
# DOMAIN - used only for admin tools: Traefik, Portainer, pgAdmin, RedisInsight, Uptime Kuma.
#   Example: traefik.example.com, docker.example.com, pgadmin.db.example.com, redis.db.example.com
#   Local: local.com (add to hosts file, see README)
# Apps define their own domains in their compose files (see Multi-Environment README).
DOMAIN=example.com
# Comma-separated public IPs/CIDRs allowed to reach admin UIs through Traefik.
# Example: 203.0.113.10/32 or 203.0.113.10/32,198.51.100.0/24
# Change this on the server whenever your public IP changes, then redeploy Traefik.
ADMIN_IP_ALLOWLIST=203.0.113.10/32
# Expose Portainer through Traefik only when needed.
PORTAINER_EXPOSE=false

# -----------------------------------------------------------------------------
# Let's Encrypt (ACME)
# -----------------------------------------------------------------------------
ACME_EMAIL=admin@example.com

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=postgres

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
# Redis users are defined directly in redis/.users.acl.
# Set below the container memory limit. For mixed BullMQ + cache usage, prefer
# noeviction so Redis rejects new writes instead of silently evicting queue data.
REDIS_MAXMEMORY=768mb
REDIS_MAXMEMORY_POLICY=noeviction
# Define redis_admin and app users in redis/.users.acl.

# -----------------------------------------------------------------------------
# pgAdmin
# -----------------------------------------------------------------------------
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=CHANGE_ME_PGADMIN_PASSWORD

# -----------------------------------------------------------------------------
# Optional: Staging ACME (for testing)
# -----------------------------------------------------------------------------
# Uncomment in docker-compose.yml to use Let's Encrypt staging server
# and avoid rate limits during testing. Certificates will show as untrusted.

# -----------------------------------------------------------------------------
# Optional: Postgres Backup Upload to S3
# -----------------------------------------------------------------------------
# Best on EC2: use an IAM role on the instance so no AWS keys are stored here.
# If not using an instance role, configure AWS credentials on the host via:
# - environment variables (AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY / AWS_REGION)
# - or `aws configure`
S3_BUCKET=
S3_PREFIX=postgres
AWS_REGION=us-east-1
# Optional for S3-compatible storage like Cloudflare R2 or MinIO
S3_ENDPOINT_URL=
